        function updateTimeModeUI() {
            const mode = document.querySelector('input[name="time_mode"]:checked')?.value;
            const relativeArea = document.getElementById('relative-area');
            const absoluteArea = document.getElementById('absolute-area');

            if (!relativeArea || !absoluteArea) return;

            if (mode === 'absolute') {
                relativeArea.classList.add('is-hidden');
                absoluteArea.classList.remove('is-hidden');
            } else {
                relativeArea.classList.remove('is-hidden');
                absoluteArea.classList.add('is-hidden');
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            updateTimeModeUI();

            document.querySelectorAll('input[name="time_mode"]').forEach(radio => {
                radio.addEventListener('change', updateTimeModeUI);
            });

            document.querySelectorAll('.quick-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const val = parseInt(this.getAttribute('data-val'));
                    const input = document.getElementById('minutes-offset');
                    if (val === 0) {
                        input.value = 0;
                    } else {
                        const current = parseInt(input.value) || 0;
                        input.value = current + val;
                    }
                });
            });
        });

        document.getElementById('main-search-form').addEventListener('submit', function() {
            const mode = document.querySelector('input[name="time_mode"]:checked').value;
            const hiddenDate = document.getElementById('hidden-date');
            const hiddenTime = document.getElementById('hidden-time');

            if (mode === 'relative') {
                const offset = parseInt(document.getElementById('minutes-offset').value) || 0;
                const now = new Date();
                now.setMinutes(now.getMinutes() + offset);

                const yyyy = now.getFullYear();
                const mm = String(now.getMonth() + 1).padStart(2, '0');
                const dd = String(now.getDate()).padStart(2, '0');
                const hh = String(now.getHours()).padStart(2, '0');
                const min = String(now.getMinutes()).padStart(2, '0');

                hiddenDate.value = `${yyyy}-${mm}-${dd}`;
                hiddenTime.value = `${hh}:${min}`;
            } else {
                hiddenDate.value = document.getElementById('exact-date').value;
                hiddenTime.value = document.getElementById('exact-time').value;
            }
        });
    </script>
</html>